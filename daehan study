<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3-5반 AI 맞춤형 스터디 플래너</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;700&display=swap');
        
        body {
            font-family: 'Pretendard', sans-serif;
            background-color: #f1f5f9;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        }

        .tab-active {
            background-color: #3b82f6;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }

        input[type="checkbox"]:checked + label {
            text-decoration: line-through;
            color: #94a3b8;
        }

        @keyframes pulse-soft {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        .animate-pulse-soft { animation: pulse-soft 2s infinite; }

        .loading-dots:after {
            content: '.';
            animation: dots 1s steps(5, start) infinite;
        }
        @keyframes dots {
            0%, 20% { content: '.'; }
            40% { content: '..'; }
            60% { content: '...'; }
            80%, 100% { content: ''; }
        }

        /* Error Message Style */
        .error-message {
            color: #ef4444;
            background-color: #fef2f2;
            padding: 0.75rem;
            border-radius: 0.75rem;
            border: 1px solid #fee2e2;
            margin-top: 0.5rem;
            font-size: 0.875rem;
        }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-slate-800 tracking-tight">3학년 5반 AI 플래너</h1>
                <p class="text-slate-500">Gemini와 함께하는 과학·수학·역사 집중 관리</p>
            </div>
            <div id="current-date" class="text-right font-semibold text-blue-600 bg-blue-50 px-5 py-2.5 rounded-2xl border border-blue-100 shadow-sm">
                로딩 중...
            </div>
        </header>

        <!-- Day Selector Tabs -->
        <div class="flex flex-wrap gap-2 mb-8">
            <button onclick="changeDay('월')" class="day-tab px-6 py-2.5 rounded-xl font-bold bg-white text-slate-600 shadow-sm transition-all hover:bg-slate-50 border border-slate-200" data-day="월">월요일</button>
            <button onclick="changeDay('화')" class="day-tab px-6 py-2.5 rounded-xl font-bold bg-white text-slate-600 shadow-sm transition-all hover:bg-slate-50 border border-slate-200" data-day="화">화요일</button>
            <button onclick="changeDay('수')" class="day-tab px-6 py-2.5 rounded-xl font-bold bg-white text-slate-600 shadow-sm transition-all hover:bg-slate-50 border border-slate-200" data-day="수">수요일</button>
            <button onclick="changeDay('목')" class="day-tab px-6 py-2.5 rounded-xl font-bold bg-white text-slate-600 shadow-sm transition-all hover:bg-slate-50 border border-slate-200" data-day="목">목요일</button>
            <button onclick="changeDay('금')" class="day-tab px-6 py-2.5 rounded-xl font-bold bg-white text-slate-600 shadow-sm transition-all hover:bg-slate-50 border border-slate-200" data-day="금">금요일</button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Timetable & AI Tutor -->
            <div class="lg:col-span-1 space-y-6">
                <!-- AI Tutor Card -->
                <div class="glass-card rounded-3xl p-6 border-2 border-blue-200 bg-gradient-to-b from-blue-50 to-white">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-3 text-slate-800">
                        <i class="fas fa-robot text-blue-500"></i> AI 개념 튜터 ✨
                    </h2>
                    <div class="space-y-4">
                        <p class="text-xs text-slate-500 leading-relaxed">궁금한 과학, 수학, 역사 용어를 입력하세요.</p>
                        <div class="relative">
                            <input type="text" id="ai-concept-input" onkeypress="if(event.keyCode==13) askAITutor()" placeholder="예: 광합성, 피타고라스" class="w-full p-3 rounded-xl border border-blue-100 text-sm focus:ring-2 focus:ring-blue-400 focus:outline-none pr-10">
                            <button onclick="askAITutor()" class="absolute right-2 top-2 text-blue-500 hover:text-blue-700 p-1">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                        <div id="ai-tutor-response" class="text-sm text-slate-700 bg-white p-4 rounded-xl border border-blue-50 hidden min-h-[60px] whitespace-pre-wrap">
                            <!-- AI Response -->
                        </div>
                    </div>
                </div>

                <!-- Academy & Meal Card -->
                <div class="glass-card rounded-3xl p-6 border-l-4 border-l-purple-500">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-3 text-slate-800">
                        <i class="fas fa-calendar-check text-purple-500"></i> 외부 스케줄
                    </h2>
                    <div id="academy-schedule" class="space-y-3">
                        <!-- Dynamic content -->
                    </div>
                </div>

                <!-- School Timetable Card -->
                <div class="glass-card rounded-3xl p-6">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-3 text-slate-800">
                        <i class="fas fa-school text-orange-500"></i> 학교 시간표
                    </h2>
                    <div id="timetable-list" class="space-y-2">
                        <!-- Dynamic content -->
                    </div>
                </div>
            </div>

            <!-- Middle Column: Study Sessions & Checklist -->
            <div class="lg:col-span-2 space-y-6">
                <!-- AI Strategy Box -->
                <div class="glass-card rounded-3xl p-6 bg-gradient-to-br from-white to-blue-50">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <h2 class="text-2xl font-bold text-slate-800">오늘의 학습 전략</h2>
                                <button onclick="generateAIAdvice()" class="text-xs bg-blue-600 text-white px-3 py-1 rounded-full hover:bg-blue-700 transition-all shadow-sm">
                                    ✨ AI 조언 받기
                                </button>
                            </div>
                            <div id="ai-advice-container" class="text-sm text-slate-600 font-medium italic animate-pulse-soft">
                                버튼을 눌러 인공지능 학습 조언을 확인하세요!
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="px-3 py-1 bg-slate-800 text-white text-xs font-bold rounded-full">과·수·역 집중모드</span>
                        </div>
                    </div>

                    <!-- Sessions -->
                    <div id="session-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Dynamic content -->
                    </div>
                </div>

                <!-- Checklist -->
                <div class="glass-card rounded-3xl p-8">
                    <div class="flex justify-between items-center mb-8">
                        <h2 class="text-2xl font-bold">성과 체크리스트</h2>
                        <div class="flex items-center gap-5 text-right">
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider">Score</p>
                                <p id="total-score-display" class="text-4xl font-black text-blue-600">0 <span class="text-lg text-slate-300">/ 25</span></p>
                            </div>
                            <div id="grade-badge" class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center text-3xl font-black text-slate-300 border-2 border-slate-200 transition-all duration-300">
                                -
                            </div>
                        </div>
                    </div>

                    <div class="space-y-3" id="checklist-container">
                        <!-- Checklist Items -->
                    </div>
                </div>

                <!-- Motivation Box -->
                <div class="bg-slate-800 rounded-3xl p-6 text-white shadow-xl relative overflow-hidden">
                    <div class="absolute -right-4 -bottom-4 opacity-10">
                        <i class="fas fa-quote-right text-8xl"></i>
                    </div>
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-fire text-orange-400 animate-pulse-soft"></i>
                            <h2 class="text-xl font-bold">AI 동기 부여 ✨</h2>
                        </div>
                        <button onclick="getMotivationalQuote()" class="text-xs bg-slate-700 hover:bg-slate-600 px-3 py-1 rounded-lg border border-slate-600 transition-colors">새 메시지</button>
                    </div>
                    <p id="ai-motivation" class="text-slate-300 leading-relaxed font-medium min-h-[3rem]">
                        "성장은 꾸준함에서 나옵니다. 오늘 하루도 당신을 응원합니다!"
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div id="modal" class="fixed inset-0 bg-slate-900/60 hidden items-center justify-center p-4 z-50">
        <div class="bg-white rounded-3xl p-10 max-w-sm w-full text-center shadow-2xl">
            <div id="modal-icon" class="text-7xl mb-6">🏆</div>
            <h3 id="modal-title" class="text-2xl font-bold mb-3 text-slate-800">축하합니다!</h3>
            <p id="modal-desc" class="text-slate-500 mb-8"></p>
            <button onclick="closeModal()" class="w-full py-4 bg-blue-600 text-white rounded-2xl font-bold hover:bg-blue-700 shadow-lg transition-all">확인</button>
        </div>
    </div>

    <script>
        const apiKey = "";
        const modelName = "gemini-2.5-flash-preview-09-2025";
        
        const studyPlan = {
            '월': {
                academy: '영어학원 (17:00 ~ 19:00)',
                dinner: '19:00 ~ 20:00 (학원 후 식사)',
                timetable: ['중국어', '사회', '영어', '과학', '국어', '역사'],
                sessions: [
                    { name: '복습 세션 1', time: '20:00 ~ 21:30', focus: '과학 / 수학' },
                    { name: '복습 세션 2', time: '21:30 ~ 22:30', focus: '역사 / 숙제' }
                ]
            },
            '화': {
                academy: '영어학원 (17:00 ~ 19:00)',
                dinner: '19:00 ~ 20:00 (학원 후 식사)',
                timetable: ['수학', '국어', '영어', '과학', '진로', '체육', '동아리'],
                sessions: [
                    { name: '복습 세션 1', time: '20:00 ~ 21:30', focus: '수학 집중' },
                    { name: '복습 세션 2', time: '21:30 ~ 22:30', focus: '과학 / 역사' }
                ]
            },
            '수': {
                academy: '기타학원 (19:00 ~ 20:00)',
                dinner: '18:00 ~ 19:00 (학원 전 식사)',
                timetable: ['음악', '가정', '수학', '과학', '국어', '학스3'],
                sessions: [
                    { name: '방과 후 세션', time: '16:30 ~ 18:00', focus: '과학 / 수학' },
                    { name: '밤 마무리 세션', time: '20:30 ~ 22:00', focus: '역사 정독' }
                ]
            },
            '목': {
                academy: '영어학원 (17:00 ~ 19:00)',
                dinner: '19:00 ~ 20:00 (학원 후 식사)',
                timetable: ['수학', '역사', '음악', '영어', '과학', '체육', '사회'],
                sessions: [
                    { name: '복습 세션 1', time: '20:00 ~ 21:30', focus: '역사 / 과학' },
                    { name: '복습 세션 2', time: '21:30 ~ 22:30', focus: '수학 문제풀이' }
                ]
            },
            '금': {
                academy: '학원 없음 (자율 학습)',
                dinner: '18:00 ~ 19:00 (정시 식사)',
                timetable: ['영어', '사회', '국어', '기술', '체육', '기술'],
                sessions: [
                    { name: '금요 세션 1', time: '19:00 ~ 20:30', focus: '과학 총정리' },
                    { name: '금요 세션 2', time: '20:30 ~ 22:00', focus: '수학 오답노트' }
                ]
            }
        };

        const checklistItems = [
            { id: 'check-1', label: '핸드폰 분리 (가족에게 맡기기)', sub: '학습 시작 전 핸드폰을 완전히 멀리했나요?' },
            { id: 'check-2', label: '과학·수학·역사 핵심 복습', sub: '오늘의 3대 중점 과목을 꼼꼼히 훑었나요?' },
            { id: 'check-3', label: '학습 세션 시간 엄수', sub: '90분 혹은 정해진 세션을 끝까지 마쳤나요?' },
            { id: 'check-4', label: '취침 전 30분 디지털 디톡스', sub: '자기 전 화면 대신 명상이나 독서를 했나요?' },
            { id: 'check-5', label: '완료 보상 누리기', sub: '오늘 고생한 자신에게 작은 휴식을 선물했나요?' }
        ];

        let currentDay = '월';
        let currentScore = 0;

        // --- Core Gemini API Call Function ---
        async function callGemini(userQuery) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/${modelName}:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: userQuery }] }]
            };

            // Retry logic with exponential backoff (up to 5 times)
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                    
                    const data = await response.json();
                    const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
                    if (text) return text;
                    throw new Error("Invalid response format");
                } catch (error) {
                    if (i === 4) throw error; // Re-throw if all retries fail
                    const delay = Math.pow(2, i) * 1000;
                    await new Promise(resolve => setTimeout(resolve, delay));
                }
            }
        }

        async function generateAIAdvice() {
            const container = document.getElementById('ai-advice-container');
            container.classList.remove('animate-pulse-soft');
            container.innerHTML = 'AI 분석 중<span class="loading-dots"></span>';
            
            try {
                const prompt = `중학교 3학년 학생의 스케줄 분석 조언을 해줘. 오늘은 ${currentDay}요일이고, 수업은 [${studyPlan[currentDay].timetable.join(', ')}], 학원은 [${studyPlan[currentDay].academy}]야. 집중 과목은 과학, 수학, 역사야. 친근한 선생님 말투로 60자 이내 짧게 한국어로 말해줘.`;
                const result = await callGemini(prompt);
                container.textContent = result;
            } catch (err) {
                container.innerHTML = '<span class="error-message">조언을 불러오지 못했습니다. 다시 시도해 주세요.</span>';
            }
        }

        async function askAITutor() {
            const input = document.getElementById('ai-concept-input');
            const resBox = document.getElementById('ai-tutor-response');
            const concept = input.value.trim();
            if (!concept) return;

            resBox.classList.remove('hidden');
            resBox.innerHTML = 'AI 튜터가 생각 중입니다<span class="loading-dots"></span>';
            
            try {
                const prompt = `중3 수준에서 "${concept}"을 쉽게 설명해줘. 과학, 수학, 역사와 관련 있다면 더 좋아. 비유를 써서 150자 이내로 한국어로 작성해줘.`;
                const result = await callGemini(prompt);
                resBox.innerHTML = result;
            } catch (err) {
                resBox.innerHTML = '<span class="error-message">답변 생성 중 오류가 발생했습니다.</span>';
            }
        }

        async function getMotivationalQuote() {
            const quoteEl = document.getElementById('ai-motivation');
            quoteEl.innerHTML = 'AI 동기 부여 생성 중<span class="loading-dots"></span>';
            
            try {
                const prompt = `내 오늘 점수는 ${currentScore}점이야 (25점 만점). 이 점수에 맞춰서 나를 응원하거나 자극하는 짧고 멋진 문구를 한글로 만들어줘. 80자 이내.`;
                const result = await callGemini(prompt);
                quoteEl.textContent = result;
            } catch (err) {
                quoteEl.textContent = "가장 큰 위험은 아무것도 하지 않는 것이다. 다시 힘을 내봐요!";
            }
        }

        function changeDay(day) {
            currentDay = day;
            document.querySelectorAll('.day-tab').forEach(t => {
                t.classList.toggle('tab-active', t.getAttribute('data-day') === day);
                if (t.getAttribute('data-day') !== day) t.classList.add('bg-white', 'text-slate-600');
            });

            const dayData = studyPlan[day];
            
            // Academy/Meal
            document.getElementById('academy-schedule').innerHTML = `
                <div class="flex items-center justify-between p-3 bg-purple-50 rounded-2xl border border-purple-100">
                    <span class="text-sm font-bold text-purple-700">학원</span>
                    <span class="text-sm font-semibold text-purple-900">${dayData.academy}</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-red-50 rounded-2xl border border-red-100">
                    <span class="text-sm font-bold text-red-700">저녁</span>
                    <span class="text-sm font-semibold text-red-900">${dayData.dinner}</span>
                </div>
            `;

            // Timetable
            document.getElementById('timetable-list').innerHTML = dayData.timetable.map((s, i) => `
                <div class="flex items-center gap-3 p-2.5 bg-slate-50 rounded-xl border border-slate-100">
                    <span class="w-6 h-6 flex items-center justify-center bg-white border border-slate-200 text-[10px] font-black rounded-lg text-slate-400">${i+1}</span>
                    <span class="font-bold text-slate-700 text-sm">${s}</span>
                </div>
            `).join('');

            // Sessions
            document.getElementById('session-grid').innerHTML = dayData.sessions.map((s, i) => `
                <div class="bg-white p-5 rounded-2xl border border-blue-100 shadow-sm">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-[10px] font-black text-blue-400 uppercase">Session ${i+1}</span>
                        <span class="text-[10px] bg-blue-50 text-blue-600 px-2 py-0.5 rounded-full font-bold">${s.time}</span>
                    </div>
                    <h3 class="font-bold text-slate-800 mb-1">${s.name}</h3>
                    <p class="text-sm text-slate-500 font-medium">집중: <span class="text-blue-600 font-bold">${s.focus}</span></p>
                </div>
            `).join('');

            // Reset AI components
            document.getElementById('ai-tutor-response').classList.add('hidden');
            document.getElementById('ai-advice-container').innerHTML = '버튼을 눌러 인공지능 학습 조언을 확인하세요!';
            document.getElementById('ai-advice-container').classList.add('animate-pulse-soft');
            
            renderChecklist();
            updateScore();
        }

        function renderChecklist() {
            const container = document.getElementById('checklist-container');
            container.innerHTML = checklistItems.map(item => `
                <div class="flex items-center p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:bg-white transition-all group cursor-pointer" onclick="toggleCheckbox('${item.id}')">
                    <input type="checkbox" id="${item.id}" class="w-6 h-6 rounded-lg border-slate-300 text-blue-600 focus:ring-blue-500" onchange="updateScore()" onclick="event.stopPropagation()">
                    <label for="${item.id}" class="ml-4 flex-1 cursor-pointer">
                        <span class="block font-bold text-slate-700 group-hover:text-blue-600">${item.label}</span>
                        <span class="text-sm text-slate-500">${item.sub}</span>
                    </label>
                    <span class="font-bold text-blue-500">+5</span>
                </div>
            `).join('');
        }

        function updateScore() {
            const checks = document.querySelectorAll('input[type="checkbox"]:checked');
            currentScore = checks.length * 5;
            document.getElementById('total-score-display').innerHTML = `${currentScore} <span class="text-lg text-slate-300">/ 25</span>`;
            
            const badge = document.getElementById('grade-badge');
            let grade = '-';
            let cls = 'text-slate-300 bg-slate-50 border-slate-200';

            if(currentScore >= 20) { grade = 'S'; cls = 'text-yellow-600 bg-yellow-50 border-yellow-400'; }
            else if(currentScore >= 15) { grade = 'A'; cls = 'text-blue-600 bg-blue-50 border-blue-400'; }
            else if(currentScore >= 10) { grade = 'B'; cls = 'text-green-600 bg-green-50 border-green-400'; }
            else if(currentScore > 0) { grade = 'C'; cls = 'text-orange-600 bg-orange-50 border-orange-400'; }

            badge.textContent = grade;
            badge.className = `w-16 h-16 rounded-2xl flex items-center justify-center text-3xl font-black border-2 transition-all duration-300 shadow-sm ${cls}`;

            if(currentScore === 25) {
                showModal("미션 완벽 클리어!", "과학, 수학, 역사 집중 학습부터 생활 습관까지 오늘 하루 완벽했습니다!", "👑");
            }
        }

        function toggleCheckbox(id) {
            const cb = document.getElementById(id);
            if(cb) {
                cb.checked = !cb.checked;
                updateScore();
            }
        }

        function showModal(title, desc, icon) {
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-desc').textContent = desc;
            document.getElementById('modal-icon').textContent = icon;
            document.getElementById('modal').classList.replace('hidden', 'flex');
        }

        function closeModal() {
            document.getElementById('modal').classList.replace('flex', 'hidden');
        }

        function updateDateTime() {
            const now = new Date();
            const days = ['일', '월', '화', '수', '목', '금', '토'];
            document.getElementById('current-date').textContent = `${now.getFullYear()}년 ${now.getMonth() + 1}월 ${now.getDate()}일 (${days[now.getDay()]})`;
            
            const todayIdx = now.getDay();
            const initialDay = (todayIdx === 0 || todayIdx === 6) ? '월' : days[todayIdx];
            changeDay(initialDay);
        }

        window.onload = updateDateTime;
    </script>
</body>
</html>
